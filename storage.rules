rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Documents KYC — un utilisateur peut uploader dans son propre dossier
    match /kyc/{userId}/{fileName} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.role == 'ADMIN');
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024 && // max 10 Mo
        request.resource.contentType.matches('image/.*');
    }

    // Contrats PDF — lecture par le propriétaire ou un admin, écriture par le propriétaire
    match /contracts/{userId}/{fileName} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.role == 'ADMIN');
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType == 'application/pdf';
    }

    // Tout le reste est interdit
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
