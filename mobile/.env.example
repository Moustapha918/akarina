# ─────────────────────────────────────────────────────────────
# Akarina — Variables d'environnement Firebase
#
# Comment utiliser :
#   cp .env.example .env.dev     → projet Firebase de dev
#   cp .env.example .env.staging → projet Firebase de préprod
#   cp .env.example .env.prod    → projet Firebase de production
#
# Récupère les valeurs depuis :
#   console.firebase.google.com
#   → Ton projet → ⚙️ Paramètres → Vos applications → SDK Firebase
# ─────────────────────────────────────────────────────────────

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
